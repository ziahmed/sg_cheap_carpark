# GEMINI_API_KEY: Required for the AI Advisor (Gemini) recommendations.
# Get a free key at https://aistudio.google.com/apikey (no billing account needed).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The public URL where this app is hosted.
# Used for self-referential links and as part of the User-Agent sent to the
# Nominatim geocoding API (required by their usage policy).
APP_URL="MY_APP_URL"

# ORS_API_KEY: Optional. Powers turn-by-turn driving directions via
# OpenRouteService (free tier, no billing/credit card required — just an
# email signup at https://openrouteservice.org/dev/#/signup).
# If left unset, the app falls back to the public OSRM demo routing server,
# which works out of the box but is rate-limited and not recommended for
# real production traffic.
ORS_API_KEY=""

# ONEMAP_EMAIL / ONEMAP_PASSWORD: Optional. Enables OneMap — Singapore's
# official government geocoder (Singapore Land Authority) — as the primary
# address/postal code search source, with far better Singapore-specific
# coverage than OpenStreetMap/Nominatim (especially for exact postal codes).
# Free account signup at https://www.onemap.gov.sg/apidocs/register — no
# billing/credit card required.
# If left unset, the app falls back to Nominatim-only search (still works,
# just with weaker postal code coverage for some addresses).
ONEMAP_EMAIL=""
ONEMAP_PASSWORD=""

# Note: no Google Maps Platform key is required. Map tiles are served for
# free via OpenFreeMap (https://openfreemap.org), and geocoding uses OneMap
# (if configured) with OpenStreetMap Nominatim as a fallback — both proxied
# through this server.
